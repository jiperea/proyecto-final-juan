# FE-1 · Configuración del frontend
#
# ARQUITECTURA: el frontend llama SIEMPRE a rutas relativas /v1/* (mismo origen).
# No hay URL de backend en el bundle. No hay secretos en el frontend:
#   - el access token llega en la respuesta de login y vive SOLO en memoria (nunca en storage);
#   - el refresh y csrf_token van en cookies (las emite el backend).
#
# Único knob de entorno: el destino del proxy /v1 en DESARROLLO (Vite).
# En producción, el reverse-proxy/servidor web enruta /v1 al backend (no se usa esta variable).

# Origen del backend al que Vite proxya /v1 en dev. Backend local por defecto (PORT=3000).
# Con docker-compose (fase DevOps DO-2) sería http://backend:3000.
VITE_BACKEND_ORIGIN=http://localhost:3000

# ── Usuarios semilla para probar (backend/prisma/seed-data.ts) ──────────────────────────────────────
# NO son variables que use el front (el login se hace en la UI); van aquí solo como REFERENCIA cómoda.
# Son credenciales de PRUEBA locales (no secretos de producción). Contraseña común para todos:
#   SEED_PASSWORD=SuperSecret123!
# Usuarios (identifier = username o email; @fieldops.test):
#   technician1  (technician@fieldops.test)   → rol technician   ← ve SUS órdenes activas
#   dispatcher1  (dispatcher@fieldops.test)   → rol dispatcher   ← ve assigned/in_progress (master-detail)
#   supervisor1  (supervisor@fieldops.test)   → rol supervisor   ← ve pending_review (master-detail)
#   technician2 / technician3                 → rol technician   (más técnicos)
#   disabled1    (disabled@fieldops.test)     → deshabilitado    (para probar 401/cuenta disabled)
#   locked1      (locked@fieldops.test)       → bloqueado        (para probar lockout)
#   reassignsrc / reassigndst                 → technician       (para pruebas de reasignación, FE-3)
