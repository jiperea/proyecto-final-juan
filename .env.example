# Copia este fichero a .env (gitignored) y rellena los valores. NUNCA commitees secretos (Constitution IX).

# Proveedor de IA (componente de resumen).
# En desarrollo y evals se usa el CLI de Claude Code (`claude -p`) → SIN clave de API ni gasto extra
# (cubierto por el plan de empresa). Solo se necesita API key si se despliega a producción.
AI_PROVIDER=claude-cli    # claude-cli (dev/eval, sin coste API) | api (prod)
# AI_API_KEY=             # solo cuando AI_PROVIDER=api (producción)

# Base de datos: PostgreSQL en todos los entornos vía Docker (Prisma).
DATABASE_URL="postgresql://fieldops:fieldops@localhost:5432/fieldops?schema=public"
# BD de test INDEPENDIENTE (docker-compose, perfil test)
TEST_DATABASE_URL="postgresql://fieldops:fieldops@localhost:5433/fieldops_test?schema=public"

# Autenticación / sesión
JWT_SECRET=
SESSION_TTL_SECONDS=900

# Almacenamiento de evidencia (URLs firmadas ≤ 300 s)
SIGNED_URL_TTL_SECONDS=300
