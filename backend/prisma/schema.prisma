// FieldOps 001 — esquema de identidad (data-model.md). Postgres 16.
// IDs UUID v7 generados en la app; tiempos timestamptz (UTC).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  dispatcher
  technician
  supervisor
}

model User {
  id           String    @id @db.Uuid
  email        String
  username     String
  passwordHash String    @map("password_hash")
  role         Role
  lockedUntil  DateTime? @map("locked_until") @db.Timestamptz(3)
  disabledAt   DateTime? @map("disabled_at") @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  identifiers Identifier[]
  sessions    Session[]
  orders      Order[]
  auditsAsActor OrderAudit[] @relation("OrderAuditActor")
  auditsAsFrom  OrderAudit[] @relation("OrderAuditFromAssignee")
  auditsAsTo    OrderAudit[] @relation("OrderAuditToAssignee")

  @@map("users")
}

// Espacio de unicidad GLOBAL email+username (D11/FR-001b): cada identidad aporta sus
// identifiers normalizados aquí; `norm` único impide username(A) == email(B).
model Identifier {
  id     String @id @db.Uuid
  norm   String @unique
  kind   String // "email" | "username"
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("identifiers")
}

model Session {
  id          String    @id @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceLabel String?   @map("device_label")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(3)

  refreshTokens RefreshToken[]

  @@map("sessions")
}

model RefreshToken {
  id         String    @id @db.Uuid
  sessionId  String    @map("session_id") @db.Uuid
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  rotatedAt  DateTime? @map("rotated_at") @db.Timestamptz(3)
  replacedBy String?   @map("replaced_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("refresh_tokens")
}

// Fixture de RBAC (D10/FR-017b). No es dominio real (Order llega en 002).
model ProbeResource {
  id           String @id @db.Uuid
  inScopeRoles Role[] @map("in_scope_roles")

  @@map("probe_resources")
}

// Feature 002a — Order (read-side). status como DATO (transiciones en 002b).
enum OrderStatus {
  draft
  assigned
  in_progress
  pending_review
  closed
}

model Order {
  id          String      @id @db.Uuid
  title       String
  description String
  status      OrderStatus
  assignedTo  String?     @map("assigned_to") @db.Uuid
  assignee    User?       @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  version     Int         @default(0) // concurrencia optimista (base-ready; If-Match→409 en 003/004)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  audits      OrderAudit[]

  @@index([status, assignedTo])
  @@index([createdAt])
  @@map("orders")
}

// Feature 004 — tipo de evento de auditoría (transición FSM vs reasignación de asignatario).
enum OrderAuditEventType {
  transition
  reassignment
}

// Feature 002b — OrderAudit (write-side). Append-only (TRIGGER a nivel de BD, no REVOKE — el rol es
// propietario, G2:S-002). Una fila por transición aplicada, en la MISMA transacción (atomicidad, FR-004).
// Feature 004 (aditivo): +event_type, +from/to_assignee; from/to_status RELAJADOS a nullable (NULL en
// reassignment, que no cambia estado). CHECK de invariantes por event_type en la migración.
model OrderAudit {
  id           String              @id @db.Uuid
  orderId      String              @map("order_id") @db.Uuid
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  actorId      String              @map("actor_id") @db.Uuid
  actor        User                @relation("OrderAuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  eventType    OrderAuditEventType @default(transition) @map("event_type") // 004
  fromStatus   OrderStatus?        @map("from_status") // nullable desde 004 (NULL en reassignment)
  toStatus     OrderStatus?        @map("to_status") // nullable desde 004 (NULL en reassignment)
  fromAssignee String?             @map("from_assignee") @db.Uuid // 004: asignatario origen (NULL si huérfana/transition)
  toAssignee   String?             @map("to_assignee") @db.Uuid // 004: asignatario destino (NULL en transition)
  fromUser     User?               @relation("OrderAuditFromAssignee", fields: [fromAssignee], references: [id], onDelete: Restrict)
  toUser       User?               @relation("OrderAuditToAssignee", fields: [toAssignee], references: [id], onDelete: Restrict)
  reason       String?             @db.Text // pre-saneado por el llamador; NUNCA en logs/errores (FR-009)
  at           DateTime            @default(now()) @db.Timestamptz(3)

  @@index([orderId])
  @@map("order_audit")
}
