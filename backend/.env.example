# FieldOps 001 — configuración (validada al arrancar con Zod; fail-fast, FR-016).
# Los 3 secretos deben ser DISTINTOS entre sí (pairwise-distinct, S-002/D8).

# Secretos (mín. 32 chars; distintos entre sí)
JWT_SECRET=change-me-jwt-secret-min-32-characters-long
CSRF_HMAC_SECRET=change-me-csrf-secret-min-32-characters-diff
LOCKOUT_HMAC_SECRET=change-me-lockout-secret-min-32-characters-x

# Base de datos (Postgres vía docker-compose)
DATABASE_URL=postgresql://fieldops:fieldops@localhost:5432/fieldops

# TTLs
ACCESS_TTL=900            # segundos (15 min)
REFRESH_TTL_DAYS=7
GRACE_MS=10000            # ventana de gracia de reintento de refresh (≤10 s, FR-004d)

# Lockout (FR-011)
LOCKOUT_MAX=5
LOCKOUT_WINDOW_MIN=15

# Caché de revocación por-request (D3)
SESSION_STATE_TTL_MS=30000   # TTL de seguridad de la caché (≤30 s)

# BD (fail-closed): timeout de consulta (T-002)
DB_QUERY_TIMEOUT_MS=2000

# Servidor
PORT=3000
NODE_ENV=development

# --- 007: resumen de incidencia por IA ---
AI_PROVIDER=claude-cli       # claude-cli (dev, sin API de pago) | mock (tests)
AI_TIMEOUT_MS=10000          # timeout duro del proveedor (FR-010)
AI_TEMPERATURE=0             # determinismo/reproducibilidad (FR-009b, Constitution IX/VIII)
AI_MIN_NOTES_CHARS=30        # umbral mínimo de notas crudas (FR-015, Constitution VIII)
AI_MIN_EVIDENCE=1            # nº mínimo de evidencia válida (FR-015)
AI_RATE_MAX=10               # rate-limit del endpoint IA (FR-008): 10/60s por usuario
AI_RATE_WINDOW_MS=60000

# --- 024: evidencia fotográfica binaria y visualización por URL firmada ---
EVIDENCE_ENC_KEY=change-me-evidence-enc-key-min-32-characters-x  # AES-256-GCM (mín. 32 chars; distinta de los otros secretos)
EVIDENCE_SIGN_TTL_SECONDS=300      # TTL de la firma de lectura interna (≤300 s, Constitution/S)
EVIDENCE_STAGING_TTL_HOURS=24      # TTL de blobs en staging antes de purga por GC
EVIDENCE_STORAGE_DIR=./data/evidence  # directorio del store filesystem cifrado (dev/test)
